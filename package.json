{
  "name": "flashcards",
  "version": "0.2.0",
  "description": "An Anki integration.",
  "main": "main.js",
  "scripts": {
    "dev": "rollup --config rollup.config.js -w --environment BUILD:dev",
    "build": "esbuild main.ts --bundle --external:obsidian --format=cjs --platform=browser --target=es2018 --outfile=main.js --sourcemap=inline",
    "build:rollup": "rollup --config rollup.config.js --environment BUILD:production",
    "release": "npm run build && mkdir -p dist/better-flashcards && cp main.js manifest.json dist/better-flashcards/",
    "test": "jest"
  },
  "keywords": [
    "obsidian",
    "anki",
    "flashcards"
  ],
  "author": "Mihir Patel",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^15.1.0",
    "@rollup/plugin-node-resolve": "^9.0.0",
    "@rollup/plugin-typescript": "^6.0.0",
    "@types/jest": "^29.2.0",
    "@types/node": "^14.17.4",
    "@typescript-eslint/eslint-plugin": "^5.7.0",
    "@typescript-eslint/parser": "^5.7.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.4.1",
    "jest": "^29.2.2",
    "obsidian": "https://github.com/obsidianmd/obsidian-api/tarball/master",
    "rollup": "^2.52.2",
    "rollup-plugin-copy": "^3.4.0",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^4.3.4"
  },
  "dependencies": {
    "@types/showdown": "^1.9.3",
    "showdown": "^1.9.1"
  }
}
